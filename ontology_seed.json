    },
    "family_tree": {
      "label": "Aile Ağacı",
      "entity_types": ["person"],
      "relations": ["child_of", "parent_of", "sibling_of", "spouse_of"]
    },
    "work_profile": {
      "label": "İş Profili",
      "entity_types": ["organization", "project"],
      "relations": ["works_at", "works_on"]
    },
    "credentials_vault": {
