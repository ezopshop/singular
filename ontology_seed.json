    "statement_patterns": [
      { "pattern": "adım X",              "prop": "name",        "domain": "identity", "self": true },
      { "pattern": "ismim X",             "prop": "name",        "domain": "identity", "self": true },
      { "pattern": "ben X'im",            "prop": "name",        "domain": "identity", "self": true },
      { "pattern": "doğum tarihim X",     "prop": "birth_date",  "domain": "identity", "self": true },
      { "pattern": "X'de doğdum",         "prop": "birth_place", "domain": "identity", "self": true },
      { "pattern": "doğum yerim X",       "prop": "birth_place", "domain": "identity", "self": true },
      { "pattern": "mailim X",            "prop": "email",       "domain": "credentials", "self": true },
      { "pattern": "e-postam X",          "prop": "email",       "domain": "credentials", "self": true },
      { "pattern": "telefonum X",         "prop": "phone",       "domain": "contacts", "self": true },
      { "pattern": "numaramX",            "prop": "phone",       "domain": "contacts", "self": true },
      { "pattern": "adresim X",           "prop": "address",     "domain": "places", "self": true },
      { "pattern": "X'de yaşıyorum",      "prop": "lives_in",    "domain": "places", "self": true },
      { "pattern": "şirketim X",          "prop": "works_at",    "domain": "work", "self": true },
      { "pattern": "işim X",              "prop": "works_at",    "domain": "work", "self": true },
      { "pattern": "annemin adı X",       "prop": "name",        "domain": "family", "role": "anne" },
      { "pattern": "annem X",             "prop": "name",        "domain": "family", "role": "anne" },
      { "pattern": "babamın adı X",       "prop": "name",        "domain": "family", "role": "baba" },
      { "pattern": "babam X",             "prop": "name",        "domain": "family", "role": "baba" },
      { "pattern": "X şifresi Y",         "prop": "password",    "domain": "credentials", "credential": true },
      { "pattern": "X parolası Y",        "prop": "password",    "domain": "credentials", "credential": true },
      { "pattern": "en sevdiğim X Y",     "prop": "likes",       "domain": "preferences", "like": true },
      { "pattern": "favorim X",           "prop": "likes",       "domain": "preferences", "like": true }
    ]
